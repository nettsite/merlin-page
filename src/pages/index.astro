---
import Layout from '../layouts/Layout.astro';
import LogoSparkle from '../components/LogoSparkle.astro';
import InvoiceMock from '../components/InvoiceMock.astro';
import Modal from '../components/Modal.astro';
---
<Layout title="Merlin — AI Invoice Processing">
  <!-- Nav -->
  <nav class="nav">
    <div class="nav__inner">
      <LogoSparkle height={28} />
      <div class="nav__right">
        <a href="#how-it-works" class="nav__link">How it works</a>
        <a href="#why-merlin" class="nav__link">Why Merlin</a>
        <a href="#features" class="nav__link">Features</a>
        <button class="nav__cta modal-trigger" type="button">Request access</button>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__badge">
        <svg width="12" height="12" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 1l1.8 4.2L14 7l-4.2 1.8L8 13l-1.8-4.2L2 7l4.2-1.8z" fill="currentColor"/>
        </svg>
        AI-powered · Hosted or self-hosted · Open source
      </div>
      <h1 class="hero__title">
        The accounting platform that learns your business —
        <span class="hero__title-accent">and lives inside it.</span>
      </h1>
      <p class="hero__sub">
        Purchase invoices, sales billing, the general ledger, expenses, and email campaigns — in one system.
        Merlin's AI extracts, codes, and posts documents automatically, and gets more accurate with every invoice
        it processes. Use our hosted version, or self-host for free — it's open source.
      </p>
      <div class="hero__actions">
        <button class="btn-primary modal-trigger" type="button">
          Request early access <span class="hero__arrow">→</span>
        </button>
        <a href="#how-it-works" class="btn-secondary">See how it works</a>
        <span class="hero__note">Your data never leaves your system.</span>
      </div>
      <div class="hero__mock">
        <InvoiceMock />
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="section" id="problem">
    <div class="container">
      <div class="section__label">The problem</div>
      <h2 class="section__title">Running your books is still too manual, too scattered, and not really yours.</h2>
      <div class="problem-grid">
        <div class="problem-card">
          <div class="problem-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="5" y="3" width="14" height="18" rx="1.5" />
              <line x1="8" y1="8" x2="16" y2="8" />
              <line x1="8" y1="12" x2="16" y2="12" />
              <line x1="8" y1="16" x2="13" y2="16" />
            </svg>
          </div>
          <h3>PDFs arrive. Someone opens each one.</h3>
          <p>Keys the figures into accounting software. Assigns accounts. Files the document. Repeats — every single invoice, every week.</p>
        </div>
        <div class="problem-card">
          <div class="problem-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="3" width="8" height="8" rx="1.5" />
              <rect x="13" y="3" width="8" height="8" rx="1.5" />
              <rect x="3" y="13" width="8" height="8" rx="1.5" />
              <rect x="13" y="13" width="8" height="8" rx="1.5" />
            </svg>
          </div>
          <h3>Your accounting, billing, and email tools don't talk to each other.</h3>
          <p>Invoice in one system, books in another, client emails in a third. Every month someone reconciles the gaps — and all those subscriptions add up.</p>
        </div>
        <div class="problem-card">
          <div class="problem-card__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="12" r="9" />
              <path d="M9 9 Q12 6 15 9" />
              <circle cx="9.5" cy="13" r="0.8" fill="currentColor" />
              <circle cx="14.5" cy="13" r="0.8" fill="currentColor" />
              <line x1="9" y1="17" x2="15" y2="17" />
            </svg>
          </div>
          <h3>Generic AI doesn't know your business.</h3>
          <p>Off-the-shelf tools guess at account codes from general patterns. They don't know that your Supplier A always goes to account 5100.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Merlin does -->
  <section class="section section--alt" id="how-it-works">
    <div class="container">
      <div class="section__label">What's included</div>
      <h2 class="section__title">One system for your full financial workflow.</h2>
      <div class="diff-grid">
        <div class="diff-card">
          <div class="diff-card__tag">Purchasing</div>
          <h3>AI supplier invoice processing</h3>
          <p>PDF, Word, Excel or CSV — Merlin extracts every line item, suggests GL account codes from your history, and auto-posts when it's confident. Learns your coding patterns with every invoice.</p>
        </div>
        <div class="diff-card">
          <div class="diff-card__tag">Sales &amp; Billing</div>
          <h3>Invoices, quotes, and recurring billing</h3>
          <p>Create sales invoices, quotes, and credit notes. Set up recurring billing — weekly to annual — with auto-send. Track payments, outstanding balances, and overdue accounts.</p>
        </div>
        <div class="diff-card">
          <div class="diff-card__tag">Ledger &amp; Expenses</div>
          <h3>Full GL and expense reporting</h3>
          <p>Hierarchical chart of accounts, multi-currency expenses with live rates for 160+ currencies, and expense reports by account or supplier. Proper double-entry from day one.</p>
        </div>
        <div class="diff-card">
          <div class="diff-card__tag">Email &amp; Campaigns</div>
          <h3>Transactional invoices and newsletters</h3>
          <p>Send invoice emails with custom templates and merge tags. Run email campaigns to contact lists and segments — all from the same system, no third-party email service needed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Merlin -->
  <section class="section" id="why-merlin">
    <div class="container">
      <div class="section__label">Why Merlin</div>
      <h2 class="section__title">Built for the way small businesses actually work — not the way enterprise software assumes.</h2>
      <div class="diff-grid">
        <div class="diff-card">
          <div class="diff-card__tag">No lock-in</div>
          <h3>Hosted or self-hosted — your choice</h3>
          <p>Use our hosted version for a monthly fee, or self-host for free — the full source is on GitHub. Either way, there's no proprietary black box. You can always take your data and run it yourself.</p>
        </div>
        <div class="diff-card">
          <div class="diff-card__tag">Personalised</div>
          <h3>Learns your business specifically</h3>
          <p>Not generic accounting patterns — your suppliers, your accounts, your preferences. The more you use it, the smarter it gets for <em>you</em>.</p>
        </div>
        <div class="diff-card">
          <div class="diff-card__tag">Oversight</div>
          <h3>Human review where it counts</h3>
          <p>Speed of automation on invoices Merlin knows well. A clear review queue for anything unusual. No silent errors buried in your accounts.</p>
        </div>
        <div class="diff-card">
          <div class="diff-card__tag">Complete billing cycle</div>
          <h3>Purchase, sales, and recurring — in one place</h3>
          <p>Purchase invoice processing, sales invoices, quotes, credit notes, and recurring billing (weekly to annual with auto-send). Full chart of accounts, tax handling, and document sequencing — not a simplified tracker.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section section--alt" id="features">
    <div class="container">
      <div class="section__label">Features</div>
      <h2 class="section__title">Everything in the box.</h2>
      <ul class="feature-list">
        <li><span class="check">✓</span> PDF, Word, Excel &amp; CSV ingestion — batch ZIP upload, up to 50 files at once</li>
        <li><span class="check">✓</span> AI extraction — supplier, every line item, tax, totals, with confidence scoring</li>
        <li><span class="check">✓</span> GL account suggestion from your own posting history, refined by AI</li>
        <li><span class="check">✓</span> Confidence-scored auto-posting — configurable thresholds per supplier and description pattern</li>
        <li><span class="check">✓</span> Review queue for anything below your confidence threshold</li>
        <li><span class="check">✓</span> Multi-currency expenses — live rates for 160+ currencies, finalised at payment</li>
        <li><span class="check">✓</span> Sales invoices, quotes &amp; credit notes — full outbound billing workflow</li>
        <li><span class="check">✓</span> Recurring billing — weekly to annual, auto-send, pro-rata first invoice</li>
        <li><span class="check">✓</span> Payment recording with overdue detection and balance-due tracking</li>
        <li><span class="check">✓</span> Payables &amp; receivables tracking — outstanding balances and due dates</li>
        <li><span class="check">✓</span> Expense reporting by account and by supplier</li>
        <li><span class="check">✓</span> AI performance monitoring — token spend, confidence distribution, extraction rates</li>
        <li><span class="check">✓</span> Role-based access control — granular permissions per user</li>
        <li><span class="check">✓</span> Full audit trail — every action and AI decision logged</li>
      </ul>
    </div>
  </section>

  <!-- Deployment options -->
  <section class="section" id="get-merlin">
    <div class="container">
      <div class="section__label">How to get Merlin</div>
      <h2 class="section__title">Hosted or self-hosted — it's your call.</h2>
      <div class="deploy-grid">
        <div class="deploy-card deploy-card--highlight">
          <div class="deploy-card__tag">Hosted</div>
          <h3>We run it. You log in.</h3>
          <p>No server, no setup. We handle hosting, updates, and backups. Pay a monthly fee and start processing invoices the same day. Supports multiple entities under one admin panel.</p>
          <button class="deploy-card__cta btn-primary modal-trigger" type="button">
            Request access <span class="hero__arrow">→</span>
          </button>
        </div>
        <div class="deploy-card">
          <div class="deploy-card__tag">Self-hosted · Free</div>
          <h3>Run it on your own server.</h3>
          <p>Merlin is open source under an MIT-style licence. Host it yourself, keep full control of your data, and pay nothing. Community support via GitHub.</p>
          <a class="deploy-card__cta btn-secondary" href="https://github.com/nettsite/merlin" target="_blank" rel="noopener">
            View on GitHub →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pullquote / status -->
  <section class="section pullquote">
    <div class="container container--narrow center">
      <svg class="pullquote__marks" width="36" height="28" viewBox="0 0 36 28" aria-hidden="true">
        <path d="M0 28 L0 14 Q0 4 8 0 L10 4 Q5 6 5 12 L11 12 L11 28 Z M21 28 L21 14 Q21 4 29 0 L31 4 Q26 6 26 12 L32 12 L32 28 Z" fill="currentColor"/>
      </svg>
      <p class="pullquote__text">
        Generic accounting software knows the rules.<br/>
        <span class="pullquote__accent">Merlin knows your business.</span>
      </p>
      <div class="status-bar">
        <div class="status-item"><span class="status-dot"></span> Purchase processing live</div>
        <div class="status-item"><span class="status-dot"></span> Sales &amp; billing live</div>
        <div class="status-item"><span class="status-dot"></span> Early access open</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-wrap" id="contact">
    <div class="container">
      <div class="cta">
        <svg class="cta__sparkle" width="180" height="180" viewBox="0 0 100 100" aria-hidden="true">
          <path d="M50 10 L55 45 L90 50 L55 55 L50 90 L45 55 L10 50 L45 45 Z" fill="var(--accent)"/>
        </svg>
        <h2 class="cta__title">Replace your invoice <span class="cta__accent">data entry cost.</span></h2>
        <p class="cta__sub">
          If you're currently paying someone to key invoices into your accounting software,
          Merlin is a direct replacement — with a ledger that's always up to date.
        </p>
        <button class="btn-cta modal-trigger" type="button">Get in touch  →</button>
        <p class="cta__note">No sales funnel. Just a conversation about your use case.</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer__inner">
      <LogoSparkle height={22} />
      <p>AI-powered invoice processing · Self-hosted · Built for small businesses</p>
    </div>
  </footer>

  <Modal />
</Layout>

<style>
.container { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
.container--narrow { max-width: 880px; }
.center { text-align: center; }

/* Nav */
.nav {
  padding: 18px 0;
  border-bottom: 1px solid var(--border);
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(8px);
  position: sticky;
  top: 0;
  z-index: 90;
}
.nav__inner { max-width: 1240px; margin: 0 auto; padding: 0 32px; display: flex; justify-content: space-between; align-items: center; }
.nav__right { display: flex; align-items: center; gap: 32px; }
.nav__link { font-size: 14px; color: var(--inkSoft); font-weight: 500; transition: color 0.15s; }
.nav__link:hover { color: var(--ink); }
.nav__cta {
  font-size: 14px; font-weight: 600; color: var(--accentOn); background: var(--ink);
  border: none; padding: 10px 18px; border-radius: 8px; cursor: pointer;
  transition: transform 0.1s, opacity 0.15s;
}
.nav__cta:hover { opacity: 0.9; transform: translateY(-1px); }

/* Hero */
.hero {
  padding: 80px 0 64px;
  background: linear-gradient(180deg, var(--bgAlt) 0%, var(--bg) 100%);
}
.hero__badge {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 12.5px; font-weight: 500; color: var(--accentInk);
  background: var(--accentSoft); border: 1px solid var(--accentBorder);
  padding: 6px 12px 6px 10px; border-radius: 999px; margin-bottom: 28px;
}
.hero__badge svg { color: var(--accent); }
.hero__title {
  font-size: clamp(2.4rem, 5.5vw, 4.25rem);
  font-weight: 700; line-height: 1.02; letter-spacing: -0.035em;
  color: var(--ink); max-width: 920px; margin-bottom: 24px;
}
.hero__title-accent { color: var(--accent); }
.hero__sub {
  font-size: 1.2rem; line-height: 1.6; color: var(--inkSoft);
  max-width: 640px; margin-bottom: 36px;
}
.hero__actions {
  display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-bottom: 56px;
}
.hero__arrow { color: var(--accent); }
.hero__note { font-size: 13px; color: var(--muted); }
.hero__mock { max-width: 1100px; margin: 0 auto; }

/* Buttons */
.btn-primary {
  font-size: 15px; font-weight: 600; color: var(--accentOn); background: var(--ink);
  border: none; padding: 14px 24px; border-radius: 8px; cursor: pointer;
  display: inline-flex; align-items: center; gap: 8px;
  transition: transform 0.1s, opacity 0.15s;
}
.btn-primary:hover { opacity: 0.92; transform: translateY(-1px); }
.btn-secondary {
  font-size: 15px; color: var(--ink); font-weight: 500;
  padding: 13px 18px; border: 1px solid var(--border); border-radius: 8px;
  background: var(--surface); transition: border-color 0.15s, background 0.15s;
}
.btn-secondary:hover { border-color: var(--ink); }

/* Sections */
.section { padding: 100px 0; }
.section--alt { background: var(--bgAlt); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.section__label {
  font-size: 12.5px; text-transform: uppercase; letter-spacing: 0.12em;
  font-weight: 600; color: var(--accent); margin-bottom: 14px;
}
.section__title {
  font-size: clamp(1.8rem, 3.6vw, 2.5rem); font-weight: 700;
  line-height: 1.1; letter-spacing: -0.025em; color: var(--ink);
  max-width: 780px; margin-bottom: 56px;
}

/* Problem */
.problem-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; }
.problem-card {
  background: var(--bgAlt); border: 1px solid var(--border);
  border-radius: 12px; padding: 28px;
}
.problem-card__icon {
  width: 44px; height: 44px; border-radius: 10px; background: var(--accentSoft);
  color: var(--accent);
  display: flex; align-items: center; justify-content: center; margin-bottom: 18px;
}
.problem-card h3 {
  font-size: 17px; font-weight: 600; line-height: 1.3; color: var(--ink);
  margin-bottom: 10px; letter-spacing: -0.01em;
}
.problem-card p { font-size: 14.5px; line-height: 1.6; color: var(--inkSoft); }

/* Why Merlin */
.diff-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.diff-card {
  border: 1px solid var(--border); border-radius: 12px; padding: 32px; background: var(--surface);
}
.diff-card__tag {
  font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.1em;
  font-weight: 600; color: var(--accent); margin-bottom: 12px;
}
.diff-card h3 {
  font-size: 22px; font-weight: 700; line-height: 1.2; color: var(--ink);
  margin-bottom: 12px; letter-spacing: -0.02em;
}
.diff-card p { font-size: 15px; line-height: 1.6; color: var(--inkSoft); }
.diff-card em { color: var(--accentInk); font-style: italic; }

/* Features */
.feature-list {
  list-style: none; display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 12px 28px;
}
.feature-list li {
  display: flex; gap: 12px; align-items: flex-start;
  background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
  padding: 14px 16px; font-size: 14.5px; color: var(--ink); line-height: 1.5;
}
.check {
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--accentSoft); color: var(--accent);
  display: inline-flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 13px; font-weight: 700;
}

/* Deployment */
.deploy-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.deploy-card {
  border: 1px solid var(--border); border-radius: 12px; padding: 32px;
  background: var(--surface); display: flex; flex-direction: column; gap: 12px;
}
.deploy-card--highlight { border-color: var(--accent); border-width: 1.5px; }
.deploy-card__tag {
  font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.1em;
  font-weight: 600; color: var(--accent);
}
.deploy-card h3 {
  font-size: 22px; font-weight: 700; line-height: 1.2; color: var(--ink);
  letter-spacing: -0.02em;
}
.deploy-card p { font-size: 15px; line-height: 1.6; color: var(--inkSoft); flex: 1; }
.deploy-card__cta { margin-top: 8px; align-self: flex-start; }

/* Pullquote */
.pullquote { padding: 100px 0; }
.pullquote__marks { color: var(--accent); margin-bottom: 24px; opacity: 0.9; }
.pullquote__text {
  font-size: clamp(1.5rem, 3vw, 1.875rem); font-weight: 500; line-height: 1.35;
  letter-spacing: -0.02em; color: var(--ink); margin-bottom: 32px;
}
.pullquote__accent { color: var(--accent); }
.status-bar { display: flex; justify-content: center; gap: 32px; flex-wrap: wrap; }
.status-item { display: flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--inkSoft); }
.status-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #3B7A4E; box-shadow: 0 0 0 3px rgba(59,122,78,0.15);
}

/* CTA */
.cta-wrap { padding: 0 0 100px; }
.cta {
  background: var(--ink); border-radius: 20px; padding: 72px 56px;
  text-align: center; position: relative; overflow: hidden;
  max-width: 1100px; margin: 0 auto;
}
.cta__sparkle { position: absolute; top: -40px; right: -40px; opacity: 0.08; }
.cta__title {
  font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; line-height: 1.05;
  letter-spacing: -0.03em; color: var(--bg); margin-bottom: 18px; position: relative;
}
.cta__accent { color: var(--accent); }
.cta__sub {
  font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.7);
  margin: 0 auto 32px; max-width: 580px; position: relative;
}
.btn-cta {
  font-size: 16px; font-weight: 600; color: var(--ink); background: var(--accent);
  border: none; padding: 16px 32px; border-radius: 10px; cursor: pointer;
  position: relative; transition: transform 0.1s, opacity 0.15s;
}
.btn-cta:hover { opacity: 0.94; transform: translateY(-1px); }
.cta__note { font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 18px; position: relative; }

/* Footer */
.footer { padding: 32px 0; border-top: 1px solid var(--border); }
.footer__inner { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
.footer p { font-size: 13px; color: var(--muted); }

@media (max-width: 768px) {
  .nav__right { gap: 16px; }
  .nav__link { display: none; }
  .diff-grid { grid-template-columns: 1fr; }
  .deploy-grid { grid-template-columns: 1fr; }
  .cta { padding: 48px 28px; }
  .section { padding: 64px 0; }
  .hero { padding: 56px 0 48px; }
}
</style>
