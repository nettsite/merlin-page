---
import Layout from '../layouts/Layout.astro';
import PreviewBar from '../components/PreviewBar.astro';
import LogoQuill from '../components/LogoQuill.astro';
import InvoiceMock from '../components/InvoiceMock.astro';
import Modal from '../components/Modal.astro';
---
<Layout variant="A" title="Merlin — AI Invoice Processing">
  <PreviewBar variant="A" />

  <!-- Nav -->
  <nav class="nav">
    <div class="nav__inner">
      <LogoQuill height={26} color="#0F1B3D" />
      <div class="nav__right">
        <a href="#how-it-works" class="nav__link">How it works</a>
        <a href="#why-merlin" class="nav__link">Why Merlin</a>
        <a href="#features" class="nav__link">Features</a>
        <button class="nav__cta modal-trigger" type="button">Request access</button>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__grid">
        <div>
          <div class="hero__badge">
            <span class="hero__badge-dot" aria-hidden="true"></span>
            In active use · Early access open
          </div>
          <h1 class="hero__title">
            Invoice processing<br/>
            <span class="hero__title-italic">that learns</span> your business<span class="hero__title-dot">.</span>
          </h1>
          <p class="hero__sub">
            Merlin reads supplier PDFs, extracts every line item, suggests GL accounts, and posts transactions —
            all inside your own system. It learns your specific business with every invoice.
          </p>
          <div class="hero__actions">
            <button class="btn-primary modal-trigger" type="button">Request early access  →</button>
            <a href="#how-it-works" class="btn-link">See how it works</a>
          </div>
          <p class="hero__note">Your data never leaves your system. No bureau. No outsourcing.</p>
        </div>
        <div class="hero__mock">
          <InvoiceMock />
        </div>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__label">The problem</div>
      <h2 class="section__title">
        Every invoice still needs someone to <span class="italic">open it, code it, and key it in</span>.
      </h2>
      <div class="problem-cols">
        <div class="problem-col">
          <div class="problem-col__num">i.</div>
          <h3>PDFs arrive. Someone opens each one.</h3>
          <p>Keys the figures into accounting software. Assigns accounts. Files the document. Repeats — every single invoice, every week.</p>
        </div>
        <div class="problem-col">
          <div class="problem-col__num">ii.</div>
          <h3>Outsource it and you're paying for data entry.</h3>
          <p>Your financials leave your system. Someone else's hands touch your supplier relationships and spending patterns. Then they send it back.</p>
        </div>
        <div class="problem-col">
          <div class="problem-col__num">iii.</div>
          <h3>Generic AI doesn't know your business.</h3>
          <p>Off-the-shelf tools guess at account codes from general patterns. They don't know that your Supplier A always goes to account 5100.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section" id="how-it-works">
    <div class="container">
      <div class="section__label">How it works</div>
      <h2 class="section__title">
        Four steps. Supplier PDF to <span class="italic">posted transaction</span>.
      </h2>
      <div class="steps-list">
        <div class="step-row">
          <div class="step-row__num">01</div>
          <h3>Invoice arrives</h3>
          <p>Upload a PDF manually, or drop it into a watched folder for hands-free batch ingestion. Merlin accepts any supplier format.</p>
        </div>
        <div class="step-row">
          <div class="step-row__num">02</div>
          <h3>Merlin extracts everything</h3>
          <p>Supplier, invoice number, date, due date, every line item, tax, totals. Multi-currency invoices handled with live exchange rates.</p>
        </div>
        <div class="step-row">
          <div class="step-row__num">03</div>
          <h3>Account codes suggested from your history</h3>
          <p>Merlin checks how you've coded this supplier before and applies the same logic — getting more accurate every month.</p>
        </div>
        <div class="step-row">
          <div class="step-row__num">04</div>
          <h3>High confidence, auto-posted. Low confidence, review queue.</h3>
          <p>You set the threshold. Nothing hits the ledger without meeting it. Every AI decision is logged with confidence scores.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Merlin -->
  <section class="section section--alt" id="why-merlin">
    <div class="container">
      <div class="section__label">Why Merlin</div>
      <h2 class="section__title">
        AI that knows <span class="italic">your suppliers, your accounts, your preferences</span>.
      </h2>
      <div class="diff-grid">
        <div class="diff-card">
          <h3>Your data never leaves</h3>
          <p>Merlin runs inside your own environment. Every invoice, every GL posting, every AI decision lives in your database — under your control, with a full audit trail. No third-party access.</p>
        </div>
        <div class="diff-card">
          <h3>Learns your business specifically</h3>
          <p>Not generic accounting patterns — your suppliers, your accounts, your preferences. The more you use it, the smarter it gets for <em>you</em>.</p>
        </div>
        <div class="diff-card">
          <h3>Human review where it counts</h3>
          <p>Speed of automation on invoices Merlin knows well. A clear review queue for anything unusual. No silent errors buried in your accounts.</p>
        </div>
        <div class="diff-card">
          <h3>Proper double-entry ledger</h3>
          <p>Not a simplified tracker. Full chart of accounts, tax rate handling, document sequencing. Built to support real bookkeeping work — just without the data entry.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="container">
      <div class="section__label">What's included</div>
      <h2 class="section__title">
        Every step covered, from <span class="italic">invoice to ledger</span>.
      </h2>
      <div class="feature-rows">
        <div class="feature-row"><span class="feature-row__num">01</span><span>PDF invoice ingestion — upload or watched folder batch processing</span></div>
        <div class="feature-row"><span class="feature-row__num">02</span><span>Intelligent extraction — supplier, line items, tax, totals</span></div>
        <div class="feature-row"><span class="feature-row__num">03</span><span>Multi-currency support — live rates, finalised at payment</span></div>
        <div class="feature-row"><span class="feature-row__num">04</span><span>Account code suggestion from your own posting history</span></div>
        <div class="feature-row"><span class="feature-row__num">05</span><span>Autonomous posting rules — condition-based auto-approval</span></div>
        <div class="feature-row"><span class="feature-row__num">06</span><span>Review queue for anything that needs a human eye</span></div>
        <div class="feature-row"><span class="feature-row__num">07</span><span>Payables tracking — outstanding balances and due dates</span></div>
        <div class="feature-row"><span class="feature-row__num">08</span><span>Expense reporting by account and supplier</span></div>
        <div class="feature-row"><span class="feature-row__num">09</span><span>Full audit trail — every action and AI decision logged</span></div>
        <div class="feature-row"><span class="feature-row__num">10</span><span>Multi-tenant — separate books per entity, landlord admin panel</span></div>
      </div>
    </div>
  </section>

  <!-- Pullquote -->
  <section class="pullquote">
    <div class="container">
      <p class="pullquote__text">
        Generic AI knows accounting in general.<br/>
        <span class="pullquote__accent">Merlin knows yours.</span>
      </p>
      <div class="status-bar">
        <div class="status-item"><span class="status-dot"></span> Core pipeline in production</div>
        <div class="status-item"><span class="status-dot"></span> Multi-tenant live</div>
        <div class="status-item"><span class="status-dot"></span> Early access open</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section" id="contact">
    <div class="container center">
      <h2 class="cta-section__title">
        Replace your invoice <span class="italic">data entry cost</span>.
      </h2>
      <p class="cta-section__sub">
        If you're currently paying someone to key invoices into your accounting software, Merlin is a direct
        replacement — with a ledger that's always up to date and a record of exactly how every decision was made.
      </p>
      <button class="btn-primary modal-trigger" type="button">Get in touch  →</button>
      <p class="cta-section__note">No sales funnel. Just a conversation about your use case.</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer__inner">
      <LogoQuill height={20} color="#0F1B3D" />
      <p>AI-powered invoice processing · Self-hosted · Built for small businesses</p>
    </div>
  </footer>

  <Modal />
</Layout>

<style>
.container { max-width: 1280px; margin: 0 auto; padding: 0 56px; }
.center { text-align: center; }
.italic { font-style: italic; }

/* Nav */
.nav { padding: 20px 0; border-bottom: 1px solid var(--border); }
.nav__inner { max-width: 1280px; margin: 0 auto; padding: 0 56px; display: flex; justify-content: space-between; align-items: center; }
.nav__right { display: flex; align-items: center; gap: 28px; }
.nav__link { font-size: 14px; color: var(--inkSoft); font-weight: 500; transition: color 0.15s; }
.nav__link:hover { color: var(--ink); }
.nav__cta {
  font-size: 13.5px; font-weight: 600; color: var(--bg); background: var(--ink);
  border: none; padding: 9px 18px; border-radius: 6px; cursor: pointer;
  transition: opacity 0.15s, transform 0.1s;
}
.nav__cta:hover { opacity: 0.92; transform: translateY(-1px); }

/* Hero */
.hero { padding: 72px 0 80px; }
.hero__grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 72px; align-items: center; }
.hero__badge {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 12px; font-weight: 600; color: var(--muted);
  text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 28px;
}
.hero__badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #3B7A4E; }
.hero__title {
  font-family: var(--fontDisplay);
  font-size: clamp(2.4rem, 4.8vw, 3.75rem);
  font-weight: 400; line-height: 1.02; letter-spacing: -0.025em;
  color: var(--ink); margin-bottom: 24px;
}
.hero__title-italic { font-style: italic; font-weight: 300; }
.hero__title-dot { display: inline-block; color: var(--muted); font-weight: 300; }
.hero__sub { font-size: 18px; line-height: 1.6; color: var(--inkSoft); max-width: 480px; margin-bottom: 36px; }
.hero__actions { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; margin-bottom: 22px; }
.hero__note { font-size: 13.5px; color: var(--muted); font-style: italic; }

/* Buttons */
.btn-primary {
  font-size: 15px; font-weight: 600; color: var(--bg); background: var(--ink);
  border: none; padding: 14px 24px; border-radius: 6px; cursor: pointer;
  transition: opacity 0.15s, transform 0.1s;
}
.btn-primary:hover { opacity: 0.92; transform: translateY(-1px); }
.btn-link {
  font-size: 15px; color: var(--inkSoft); font-weight: 500;
  border-bottom: 1px solid var(--muted); padding-bottom: 2px;
  transition: color 0.15s, border-color 0.15s;
}
.btn-link:hover { color: var(--ink); border-color: var(--ink); }

/* Sections */
.section { padding: 100px 0; }
.section--alt {
  background: var(--bgAlt); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
}
.section__label {
  font-size: 12px; text-transform: uppercase; letter-spacing: 0.14em;
  font-weight: 600; color: var(--muted); margin-bottom: 14px;
}
.section__title {
  font-family: var(--fontDisplay);
  font-size: clamp(1.875rem, 3.4vw, 2.625rem);
  font-weight: 400; line-height: 1.1; letter-spacing: -0.02em;
  color: var(--ink); max-width: 760px; margin-bottom: 56px;
}

/* Problem (3-col with rules) */
.problem-cols { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; }
.problem-col { padding: 0 28px; }
.problem-col + .problem-col { border-left: 1px solid var(--border); }
.problem-col__num {
  font-family: var(--fontDisplay); font-style: italic; font-size: 22px;
  color: var(--muted); font-weight: 400; margin-bottom: 14px;
}
.problem-col h3 {
  font-family: var(--fontDisplay); font-weight: 500; font-size: 22px;
  line-height: 1.25; letter-spacing: -0.01em; color: var(--ink); margin-bottom: 14px;
}
.problem-col p { font-size: 15px; line-height: 1.65; color: var(--inkSoft); }

/* Steps (numbered narrative rows) */
.steps-list { border-top: 1px solid var(--border); }
.step-row {
  display: grid; grid-template-columns: 120px 1fr 2fr; gap: 40px;
  padding: 32px 0; border-bottom: 1px solid var(--border); align-items: baseline;
}
.step-row__num {
  font-family: var(--fontDisplay); font-style: italic; font-weight: 300;
  font-size: 56px; color: var(--muted); letter-spacing: -0.04em; line-height: 1;
}
.step-row h3 {
  font-family: var(--fontDisplay); font-weight: 500; font-size: 22px;
  line-height: 1.25; letter-spacing: -0.01em; color: var(--ink);
}
.step-row p { font-size: 16px; line-height: 1.65; color: var(--inkSoft); }

/* Why Merlin */
.diff-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
  background: var(--border); border: 1px solid var(--border); border-radius: 4px;
}
.diff-card { background: var(--surface); padding: 36px 32px; }
.diff-card h3 {
  font-family: var(--fontDisplay); font-weight: 500; font-size: 22px;
  line-height: 1.25; letter-spacing: -0.01em; color: var(--ink); margin-bottom: 12px;
}
.diff-card p { font-size: 15.5px; line-height: 1.65; color: var(--inkSoft); }
.diff-card em { color: var(--muted); font-style: italic; }

/* Features */
.feature-rows { display: grid; grid-template-columns: 1fr 1fr; gap: 0 64px; border-top: 1px solid var(--border); }
.feature-row {
  padding: 18px 0; border-bottom: 1px solid var(--border);
  display: flex; gap: 16px; align-items: baseline;
}
.feature-row__num {
  font-family: var(--fontDisplay); font-style: italic; color: var(--muted);
  font-size: 14px; font-variant-numeric: tabular-nums; flex-shrink: 0;
}
.feature-row span:last-child { font-size: 15.5px; color: var(--ink); line-height: 1.55; }

/* Pullquote on dark */
.pullquote { padding: 100px 0; background: var(--ink); color: var(--bg); }
.pullquote__text {
  font-family: var(--fontDisplay); font-weight: 300; font-style: italic;
  font-size: clamp(1.5rem, 2.8vw, 2.25rem);
  line-height: 1.3; letter-spacing: -0.015em; margin-bottom: 40px;
  max-width: 880px;
}
.pullquote__accent { font-style: normal; font-weight: 400; }
.status-bar {
  display: flex; gap: 36px; flex-wrap: wrap; max-width: 880px;
  border-top: 1px solid rgba(245,240,230,0.15); padding-top: 24px;
}
.status-item {
  display: flex; align-items: center; gap: 10px;
  font-size: 13.5px; color: rgba(245,240,230,0.75);
}
.status-dot { width: 6px; height: 6px; border-radius: 50%; background: #7FAE91; }

/* CTA */
.cta-section { padding: 120px 0; }
.cta-section__title {
  font-family: var(--fontDisplay);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 400; line-height: 1.05; letter-spacing: -0.025em;
  color: var(--ink); margin-bottom: 20px; max-width: 720px; margin-inline: auto;
}
.cta-section__sub {
  font-size: 17px; line-height: 1.65; color: var(--inkSoft);
  margin: 0 auto 32px; max-width: 540px;
}
.cta-section__note { font-size: 13.5px; color: var(--muted); margin-top: 18px; font-style: italic; }

/* Footer */
.footer { padding: 32px 0; border-top: 1px solid var(--border); }
.footer__inner { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
.footer p { font-size: 13px; color: var(--muted); }

@media (max-width: 900px) {
  .container { padding: 0 28px; }
  .nav__inner { padding: 0 28px; }
  .nav__link { display: none; }
  .hero__grid { grid-template-columns: 1fr; gap: 40px; }
  .problem-cols { grid-template-columns: 1fr; gap: 24px; }
  .problem-col + .problem-col { border-left: none; border-top: 1px solid var(--border); padding-top: 24px; }
  .step-row { grid-template-columns: 1fr; gap: 8px; }
  .step-row__num { font-size: 36px; }
  .diff-grid { grid-template-columns: 1fr; }
  .feature-rows { grid-template-columns: 1fr; gap: 0; }
  .section { padding: 64px 0; }
  .hero { padding: 48px 0 56px; }
  .pullquote { padding: 64px 0; }
  .cta-section { padding: 80px 0; }
}
</style>
