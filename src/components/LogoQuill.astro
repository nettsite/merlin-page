---
// Quill logo — for Direction A (Ledger).
// Custom 'M' built from ledger strokes + Fraunces wordmark.
interface Props {
  height?: number;
  color?: string;
}
const { height = 28, color = '#0F1B3D' } = Astro.props;
const fontSize = height * 0.78;
---
<span class="logo-quill" style={`height:${height}px;`}>
  <svg viewBox="0 0 32 32" width={height} height={height} aria-hidden="true">
    <path
      d="M5 25 L5 7 L9 7 L16 18 L23 7 L27 7 L27 25 L23.5 25 L23.5 13 L17.5 22 L14.5 22 L8.5 13 L8.5 25 Z"
      fill={color}
    />
    <circle cx="26" cy="6" r="1.8" fill={color} opacity="0.5" />
  </svg>
  <span class="logo-quill__word" style={`font-size:${fontSize}px;color:${color};`}>Merlin</span>
</span>

<style>
.logo-quill {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.logo-quill__word {
  font-family: 'Fraunces', 'Source Serif Pro', Georgia, serif;
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1;
}
</style>
