---
// Reusable invoice review mock — themed via CSS custom properties on parent.
// Drop this into any page and it picks up theme tokens from the surrounding scope.
---
<div class="mock">
  <div class="mock__chrome">
    <div class="mock__dots">
      <span style="background:#FF5F57"></span>
      <span style="background:#FEBC2E"></span>
      <span style="background:#28C840"></span>
    </div>
    <div class="mock__title">merlin · review queue</div>
  </div>
  <div class="mock__body">
    <aside class="mock__queue">
      <div class="mock__queue-label">Needs review · 4</div>
      <div class="mock__row mock__row--active">
        <div class="mock__row-name">Hadebe Plumbing</div>
        <div class="mock__row-amt">R 2,840.00</div>
      </div>
      <div class="mock__row"><div class="mock__row-name">Cape Logistics</div><div class="mock__row-amt">R 18,200.50</div></div>
      <div class="mock__row"><div class="mock__row-name">Inkanyezi Press</div><div class="mock__row-amt">R 760.00</div></div>
      <div class="mock__row"><div class="mock__row-name">Stellar IT Solutions</div><div class="mock__row-amt">R 4,995.00</div></div>
    </aside>
    <div class="mock__detail">
      <div class="mock__detail-head">
        <div>
          <div class="mock__eyebrow">Invoice INV-2841</div>
          <div class="mock__supplier">Hadebe Plumbing</div>
        </div>
        <div class="mock__confidence">92% confidence</div>
      </div>
      <div class="mock__table">
        <div class="mock__thead">
          <div>Line item</div>
          <div>Suggested account</div>
          <div class="mock__r">Amount</div>
        </div>
        <div class="mock__tr">
          <div>Geyser element replacement</div>
          <div class="mock__acct">5210 · Repairs</div>
          <div class="mock__r mock__num">1,400.00</div>
        </div>
        <div class="mock__tr">
          <div>Call-out fee</div>
          <div class="mock__acct">5210 · Repairs</div>
          <div class="mock__r mock__num">650.00</div>
        </div>
        <div class="mock__tr">
          <div>Pipe fittings (×4)</div>
          <div class="mock__acct">5300 · Materials</div>
          <div class="mock__r mock__num">790.00</div>
        </div>
      </div>
      <div class="mock__foot">
        <div class="mock__foot-note">Coded the same way <strong>11 times</strong> before</div>
        <div class="mock__foot-actions">
          <button class="mock__btn-ghost" type="button">Edit coding</button>
          <button class="mock__btn-primary" type="button">Post to ledger</button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.mock {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  box-shadow: var(--shadow);
  overflow: hidden;
  font-family: 'Inter', system-ui, sans-serif;
  color: var(--ink);
  width: 100%;
}
.mock__chrome {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  background: var(--chrome);
}
.mock__dots { display: flex; gap: 6px; }
.mock__dots span { width: 10px; height: 10px; border-radius: 50%; display: block; }
.mock__title { margin-left: 14px; font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; }
.mock__body { display: grid; grid-template-columns: 200px 1fr; min-height: 360px; }
.mock__queue { border-right: 1px solid var(--border); padding: 12px 0; }
.mock__queue-label {
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted);
  padding: 0 14px 8px;
  font-weight: 600;
}
.mock__row { padding: 9px 14px; border-left: 2px solid transparent; font-size: 12.5px; }
.mock__row--active { border-left-color: var(--accent); background: var(--accentSoft); }
.mock__row-name { font-weight: 500; color: var(--ink); }
.mock__row--active .mock__row-name { font-weight: 600; }
.mock__row-amt { font-size: 11px; color: var(--muted); font-variant-numeric: tabular-nums; margin-top: 2px; }
.mock__detail { padding: 16px 18px; display: flex; flex-direction: column; gap: 14px; }
.mock__detail-head { display: flex; justify-content: space-between; align-items: flex-start; }
.mock__eyebrow {
  font-size: 11px; color: var(--muted); font-weight: 600;
  letter-spacing: 0.04em; text-transform: uppercase;
}
.mock__supplier { font-size: 17px; font-weight: 700; margin-top: 3px; color: var(--ink); letter-spacing: -0.01em; }
.mock__confidence {
  font-size: 11px; font-weight: 600; color: var(--accentInk);
  background: var(--accentSoft); border: 1px solid var(--accentBorder);
  padding: 4px 10px; border-radius: 999px; font-variant-numeric: tabular-nums;
  white-space: nowrap;
}
.mock__table { border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
.mock__thead, .mock__tr {
  display: grid; grid-template-columns: 1.6fr 1.2fr 0.7fr;
  padding: 7px 12px; align-items: center;
}
.mock__thead {
  font-size: 10.5px; color: var(--muted); background: var(--chrome);
  text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;
}
.mock__tr { font-size: 12px; padding: 9px 12px; border-top: 1px solid var(--border); }
.mock__acct { color: var(--accentInk); font-weight: 500; font-variant-numeric: tabular-nums; }
.mock__r { text-align: right; }
.mock__num { font-variant-numeric: tabular-nums; color: var(--ink); }
.mock__foot { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
.mock__foot-note { font-size: 11.5px; color: var(--muted); }
.mock__foot-note strong { color: var(--ink); font-weight: 600; }
.mock__foot-actions { display: flex; gap: 8px; }
.mock__btn-ghost {
  font-size: 12px; padding: 7px 12px; border-radius: 6px;
  border: 1px solid var(--border); background: transparent;
  color: var(--ink); cursor: pointer; font-family: inherit; font-weight: 500;
}
.mock__btn-primary {
  font-size: 12px; padding: 7px 14px; border-radius: 6px; border: none;
  background: var(--accent); color: var(--accentOn);
  cursor: pointer; font-family: inherit; font-weight: 600;
}

@media (max-width: 640px) {
  .mock__body { grid-template-columns: 1fr; }
  .mock__queue { border-right: none; border-bottom: 1px solid var(--border); }
}
</style>
